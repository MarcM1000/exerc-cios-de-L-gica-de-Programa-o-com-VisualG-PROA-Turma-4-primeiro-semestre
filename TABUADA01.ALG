Algoritmo "Tabuada01"
// Disciplina  : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Apresentar os Resultados de uma tabuada
// Autor(a)    : Marcos Vinicius
// Data atual  : 01/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   contadora, numero: inteiro

Inicio
   escreva("Digite um número para ver a tabuada: ")
   leia(numero)
   contadora <- 1
   enquanto contadora <= 10 faca
      escreva(numero, " x ", contadora, " = ", numero * contadora, "\n")
      contadora <- contadora + 1
   fimenquanto

Fimalgoritmo