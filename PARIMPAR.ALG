Algoritmo "parimpar"
// Disciplina   : Lógica de Programaçăo com o VISUALG
// Professor   : Jailson Costa Dos Santos
// Descriçăo   : numeros par e impar
// Autor(a)    : Marcos Vinicius
// Data atual  : 01/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   numero1:real



Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("digite um numero ")
   leia(numero1)
   se numero1 mod 2 = 0 entao
      escreval("o numero é par ",)
   senao
      escreval("o numero é impar ")
   fimse



Fimalgoritmo

2 5 10 20 50 100 200